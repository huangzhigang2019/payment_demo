<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal" >

   <LinearLayout
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:orientation="vertical">
       <EditText
           android:id="@+id/fragment_set_light_mode_edit"
           android:layout_width="150dp"
           android:layout_height="wrap_content"
           android:layout_marginLeft="20dp"
           android:inputType="number"
           android:text="1"
           android:hint="light mode(0-3)" />
       <EditText
           android:id="@+id/fragment_set_light_volume_edit"
           android:layout_width="150dp"
           android:layout_height="wrap_content"
           android:layout_marginLeft="20dp"
           android:inputType="number"
           android:text="3"
           android:hint="light volume(1-3)" />

       <Button
           android:id="@+id/fragment_set_light_bt"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginLeft="20dp"
           android:layout_marginTop="10dp"
           android:text="set light" />


   </LinearLayout>

    <TextView
        android:id="@+id/fragment_set_light_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:scrollbars="vertical"
        android:maxLines="5"
        android:padding="10dp" />
</LinearLayout>